---
---

<div id="cart-overlay"
     class="fixed inset-0 bg-black bg-opacity-70 z-[60] hidden transition-opacity duration-300"
     aria-hidden="true">
</div>

<aside id="cart-panel"
       class="fixed top-0 right-0 h-full w-full sm:w-96 bg-panel-dark border-l-4 border-comic-red z-[70] transform translate-x-full transition-transform duration-300 flex flex-col"
       role="dialog"
       aria-label="Shopping cart">

  <div class="flex items-center justify-between p-5 border-b-4 border-black bg-comic-red">
    <h2 class="font-bangers text-3xl text-white tracking-wide">YOUR CART</h2>
    <div class="flex items-center gap-3">
      <button id="cart-clear"
              class="hidden font-russo text-xs text-white/80 hover:text-white uppercase tracking-wide underline underline-offset-2">
        Clear
      </button>
      <button id="cart-close" class="text-white hover:text-comic-yellow transition-colors p-1" aria-label="Close cart">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <div id="cart-items-container" class="flex-1 overflow-y-auto p-4 space-y-4">
    <div id="cart-empty" class="flex flex-col items-center justify-center h-full text-center py-16">
      <div class="text-6xl mb-4">🛒</div>
      <p class="font-bangers text-2xl text-gray-400 tracking-wide">YOUR CART IS EMPTY</p>
      <p class="font-source text-gray-500 mt-2 text-sm">Add some epic wall art to get started!</p>
    </div>
    <div id="cart-list" class="hidden space-y-4"></div>
  </div>

  <div id="cart-footer" class="hidden border-t-4 border-black p-5 bg-black">

    <!-- Live free-shipping progress -->
    <div id="shipping-progress" class="mb-4 p-3 border-2 border-gray-700 bg-black">
      <p id="shipping-msg" class="font-russo text-xs uppercase tracking-wide text-gray-300 text-center mb-2">
        Add £50.00 more for FREE UK P&amp;P
      </p>
      <div class="h-1 bg-gray-800 overflow-hidden">
        <div id="shipping-fill" class="h-full bg-comic-yellow transition-all duration-500" style="width: 0%"></div>
      </div>
    </div>

    <div class="flex justify-between items-center mb-4">
      <span class="font-russo text-off-white uppercase tracking-wide">Subtotal</span>
      <span id="cart-subtotal" class="font-bangers text-comic-yellow text-2xl">£0.00</span>
    </div>

    <button id="checkout-btn" class="btn-primary w-full text-center block mb-3">CHECKOUT</button>
    <p id="checkout-error" class="hidden font-source text-comic-red text-xs text-center mb-2"></p>
    <button id="continue-shopping" class="w-full text-center font-russo text-sm text-gray-400 hover:text-comic-cyan transition-colors uppercase tracking-wide py-2">
      Continue Shopping
    </button>
  </div>
</aside>

<!-- Clear cart confirmation modal — themed to match CSC comic aesthetic -->
<div id="clear-confirm-overlay"
     class="fixed inset-0 bg-black bg-opacity-80 z-[80] hidden items-center justify-center p-4"
     aria-hidden="true">
  <div id="clear-confirm-modal"
       class="bg-panel-dark border-4 border-comic-red max-w-sm w-full transform scale-95 opacity-0 transition-all duration-200"
       style="box-shadow: 8px 8px 0 #000000;"
       role="dialog"
       aria-modal="true"
       aria-labelledby="clear-confirm-title">

    <div class="bg-comic-red border-b-4 border-black p-4 flex items-center justify-between">
      <h3 id="clear-confirm-title" class="font-bangers text-2xl text-white tracking-wide">
        EMPTY YOUR CART?
      </h3>
      <span class="font-bangers text-2xl text-white opacity-70" aria-hidden="true">!</span>
    </div>

    <div class="p-5">
      <p class="font-source text-off-white text-sm leading-relaxed mb-2">
        You're about to remove <span id="clear-confirm-count" class="font-russo text-comic-yellow">0 items</span> from your cart.
      </p>
      <p class="font-source text-gray-400 text-xs leading-relaxed mb-5">
        This can't be undone — but you can always add them back from the store.
      </p>

      <div class="flex flex-col gap-2">
        <button id="clear-confirm-yes"
                class="w-full bg-comic-yellow hover:bg-comic-red text-black hover:text-white font-bangers text-xl tracking-wide py-3 border-2 border-black transition-colors"
                style="box-shadow: 3px 3px 0 #000000;">
          YES, EMPTY IT
        </button>
        <button id="clear-confirm-no"
                class="w-full bg-transparent hover:bg-gray-800 text-gray-300 font-russo text-sm uppercase tracking-wide py-2 border-2 border-gray-700 transition-colors">
          Keep my cart
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import {
    cartOpen,
    cartItems,
    cartTotal,
    qualifiesForFreeShipping,
    amountToFreeShipping,
    FREE_SHIPPING_THRESHOLD,
    removeFromCart,
    updateQuantity,
    clearCart,
  } from '../stores/cart';
  import type { CartItem } from '../stores/cart';

  const panel = document.getElementById('cart-panel');
  const overlay = document.getElementById('cart-overlay');
  const closeBtn = document.getElementById('cart-close');
  const clearBtn = document.getElementById('cart-clear');
  const continueShopping = document.getElementById('continue-shopping');
  const cartEmpty = document.getElementById('cart-empty');
  const cartList = document.getElementById('cart-list');
  const cartFooter = document.getElementById('cart-footer');
  const cartSubtotal = document.getElementById('cart-subtotal');
  const shippingMsg = document.getElementById('shipping-msg');
  const shippingFill = document.getElementById('shipping-fill');
  const shippingProgress = document.getElementById('shipping-progress');

  function openCart() {
    panel?.classList.remove('translate-x-full');
    overlay?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeCart() {
    panel?.classList.add('translate-x-full');
    overlay?.classList.add('hidden');
    document.body.style.overflow = '';
    cartOpen.set(false);
  }

  cartOpen.subscribe((open) => {
    if (open) openCart();
    else closeCart();
  });

  closeBtn?.addEventListener('click', closeCart);
  overlay?.addEventListener('click', closeCart);
  continueShopping?.addEventListener('click', closeCart);

  clearBtn?.addEventListener('click', () => {
    if (cartItems.get().length === 0) return;
    openClearConfirm();
  });

  // ============================================================
  // Clear-cart confirmation modal
  // ============================================================
  const clearOverlay = document.getElementById('clear-confirm-overlay');
  const clearModal = document.getElementById('clear-confirm-modal');
  const clearYes = document.getElementById('clear-confirm-yes');
  const clearNo = document.getElementById('clear-confirm-no');
  const clearCount = document.getElementById('clear-confirm-count');

  function openClearConfirm() {
    if (!clearOverlay || !clearModal || !clearCount) return;

    const items = cartItems.get();
    const totalQty = items.reduce((sum, i) => sum + i.quantity, 0);
    clearCount.textContent = totalQty === 1 ? '1 item' : `${totalQty} items`;

    clearOverlay.classList.remove('hidden');
    clearOverlay.classList.add('flex');
    // Trigger the pop-in animation
    requestAnimationFrame(() => {
      clearModal.classList.remove('scale-95', 'opacity-0');
      clearModal.classList.add('scale-100', 'opacity-100');
    });
  }

  function closeClearConfirm() {
    if (!clearOverlay || !clearModal) return;
    clearModal.classList.remove('scale-100', 'opacity-100');
    clearModal.classList.add('scale-95', 'opacity-0');
    // Wait for animation, then hide
    setTimeout(() => {
      clearOverlay.classList.add('hidden');
      clearOverlay.classList.remove('flex');
    }, 200);
  }

  clearYes?.addEventListener('click', () => {
    clearCart();
    closeClearConfirm();
  });

  clearNo?.addEventListener('click', closeClearConfirm);

  // Click outside the modal to dismiss
  clearOverlay?.addEventListener('click', (e) => {
    if (e.target === clearOverlay) closeClearConfirm();
  });

  // Escape to close — modal takes precedence over cart
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    if (clearOverlay && !clearOverlay.classList.contains('hidden')) {
      closeClearConfirm();
    } else if (cartOpen.get()) {
      closeCart();
    }
  });

  const FORMAT_LABELS: Record<string, string> = {
    poster: 'Poster Print',
    'canvas-standard': 'Canvas (Standard)',
    'canvas-gallery': 'Canvas (Gallery)',
  };

  const SIZE_LABELS: Record<string, string> = {
    small: 'Small (12x8")',
    medium: 'Medium (16x12")',
    large: 'Large (24x16")',
  };

  function renderCartItems(items: CartItem[]) {
    if (!cartList || !cartEmpty || !cartFooter || !clearBtn) return;

    if (items.length === 0) {
      cartEmpty.classList.remove('hidden');
      cartList.classList.add('hidden');
      cartFooter.classList.add('hidden');
      clearBtn.classList.add('hidden');
    } else {
      cartEmpty.classList.add('hidden');
      cartList.classList.remove('hidden');
      cartFooter.classList.remove('hidden');
      clearBtn.classList.remove('hidden');

      cartList.innerHTML = items.map(item => `
        <div class="bg-charcoal border-4 border-black p-3" data-item-id="${item.id}">
          <div class="flex gap-3">
            <div class="w-16 h-16 bg-mid-grey border-2 border-gray-600 flex items-center justify-center flex-shrink-0 overflow-hidden">
              ${item.imageUrl
                ? `<img src="${item.imageUrl}" alt="${item.title}" class="w-full h-full object-contain" />`
                : `<span class="text-gray-500 text-xs font-russo">IMG</span>`
              }
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-russo text-off-white text-sm leading-tight truncate">${item.title}</p>
              <p class="font-source text-gray-400 text-xs mt-1">${FORMAT_LABELS[item.format] || item.format}</p>
              <p class="font-source text-gray-400 text-xs">${SIZE_LABELS[item.size] || item.size}</p>
              <div class="flex items-center justify-between mt-2">
                <div class="flex items-center gap-2">
                  <button class="qty-btn w-6 h-6 bg-mid-grey text-off-white hover:bg-comic-red transition-colors text-sm font-bold flex items-center justify-center" data-action="dec" data-id="${item.id}">-</button>
                  <span class="font-russo text-off-white text-sm">${item.quantity}</span>
                  <button class="qty-btn w-6 h-6 bg-mid-grey text-off-white hover:bg-comic-red transition-colors text-sm font-bold flex items-center justify-center" data-action="inc" data-id="${item.id}">+</button>
                </div>
                <span class="font-bangers text-comic-yellow text-lg">£${(item.unitPrice * item.quantity).toFixed(2)}</span>
              </div>
            </div>
            <button class="remove-btn text-gray-500 hover:text-comic-red transition-colors self-start" data-id="${item.id}" aria-label="Remove item">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            </button>
          </div>
        </div>
      `).join('');

      cartList.querySelectorAll('.remove-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const id = (e.currentTarget as HTMLElement).dataset.id;
          if (id) removeFromCart(id);
        });
      });

      cartList.querySelectorAll('.qty-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const el = e.currentTarget as HTMLElement;
          const id = el.dataset.id;
          const action = el.dataset.action;
          const item = cartItems.get().find(i => i.id === id);
          if (item && id) {
            updateQuantity(id, action === 'inc' ? item.quantity + 1 : item.quantity - 1);
          }
        });
      });
    }
  }

  cartItems.subscribe(renderCartItems);

  cartTotal.subscribe((total) => {
    if (cartSubtotal) {
      cartSubtotal.textContent = `£${total.toFixed(2)}`;
    }

    // Update progress bar fill
    if (shippingFill) {
      const pct = Math.min(100, (total / FREE_SHIPPING_THRESHOLD) * 100);
      shippingFill.style.width = `${pct}%`;
    }
  });

  // Free shipping messaging — switches between "add £X more" and "you've unlocked"
  function updateShippingMessage() {
    if (!shippingMsg || !shippingProgress) return;
    const qualified = qualifiesForFreeShipping.get();
    const remaining = amountToFreeShipping.get();
    if (qualified) {
      shippingMsg.textContent = "🎉 You've unlocked FREE UK P&P";
      shippingMsg.classList.remove('text-gray-300');
      shippingMsg.classList.add('text-comic-yellow');
      shippingProgress.classList.remove('border-gray-700');
      shippingProgress.classList.add('border-comic-yellow');
    } else {
      shippingMsg.textContent = `Add £${remaining.toFixed(2)} more for FREE UK P&P`;
      shippingMsg.classList.remove('text-comic-yellow');
      shippingMsg.classList.add('text-gray-300');
      shippingProgress.classList.remove('border-comic-yellow');
      shippingProgress.classList.add('border-gray-700');
    }
  }

  qualifiesForFreeShipping.subscribe(updateShippingMessage);
  amountToFreeShipping.subscribe(updateShippingMessage);

  // Checkout handler
  const checkoutBtn = document.getElementById('checkout-btn');
  const checkoutError = document.getElementById('checkout-error');

  checkoutBtn?.addEventListener('click', async () => {
    const items = cartItems.get();
    if (items.length === 0) return;

    checkoutBtn.textContent = 'PROCESSING...';
    checkoutBtn.setAttribute('disabled', 'true');
    checkoutBtn.classList.add('opacity-60', 'cursor-not-allowed');
    if (checkoutError) checkoutError.classList.add('hidden');

    try {
      const response = await fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          items: items.map((item) => ({
            productId: item.productId,
            slug: item.slug,
            title: item.title,
            format: item.format,
            size: item.size,
            quantity: item.quantity,
            unitPrice: item.unitPrice,
            imageUrl: item.imageUrl,
          })),
        }),
      });

      const data = await response.json();

      if (data.url) {
        window.location.href = data.url;
      } else {
        throw new Error(data.error || 'Checkout failed');
      }
    } catch (err) {
      console.error('Checkout error:', err);
      if (checkoutError) {
        checkoutError.textContent = 'Something went wrong. Please try again.';
        checkoutError.classList.remove('hidden');
      }
      checkoutBtn.textContent = 'CHECKOUT';
      checkoutBtn.removeAttribute('disabled');
      checkoutBtn.classList.remove('opacity-60', 'cursor-not-allowed');
    }
  });
</script>
