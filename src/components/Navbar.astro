---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  {
    label: 'Store',
    href: '/store',
    children: [
      { label: 'All Products', href: '/store' },
      { label: 'Comic Book Covers', href: '/store/comic-book-covers' },
      { label: 'Comic Book Icons', href: '/store/comic-book-icons' },
      { label: 'Comic Book Strips', href: '/store/comic-book-strips' },
      { label: 'Personalised', href: '/store/personalised' },
    ],
  },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-24 lg:h-28">
      <a href="/" class="flex-shrink-0">
        <img
          src="/logo.png"
          alt="Comic Strip Canvas"
          class="h-20 lg:h-24 w-auto object-contain"
        />
      </a>

      <div class="hidden lg:flex items-center space-x-6">
        {navLinks.map((link) => (
          link.children ? (
            <div class="relative group">
              <button class="nav-link flex items-center gap-1">
                {link.label}
                <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="absolute top-full left-0 mt-2 w-52 bg-panel-dark border-4 border-black opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
                   style="box-shadow: 4px 4px 0 #000000;">
                {link.children.map((child) => (
                  <a href={child.href}
                     class="block px-4 py-2 font-russo text-sm text-off-white hover:bg-comic-red hover:text-white transition-colors uppercase tracking-wide">
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a href={link.href} class="nav-link">{link.label}</a>
          )
        ))}
      </div>

      <div class="flex items-center gap-4">
        <a href="/personalise" class="hidden lg:block btn-primary text-sm py-2 px-5">
          Personalise
        </a>
        <button id="cart-toggle" class="relative p-2 text-off-white hover:text-comic-yellow transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          <span id="cart-count"
                class="absolute -top-1 -right-1 bg-comic-red text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center hidden">
            0
          </span>
        </button>

        <button id="mobile-menu-btn" class="lg:hidden p-2 text-off-white hover:text-comic-yellow transition-colors">
          <svg class="w-6 h-6" id="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="w-6 h-6 hidden" id="close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden bg-panel-dark border-t-4 border-comic-red">
    <div class="px-4 py-4 space-y-2">
      {navLinks.map((link) => (
        link.children ? (
          <div>
            <div class="font-russo text-off-white uppercase tracking-wide py-2 text-sm font-bold text-comic-yellow">
              {link.label}
            </div>
            {link.children.map((child) => (
              <a href={child.href}
                 class="block pl-4 py-2 font-source text-sm text-gray-300 hover:text-comic-yellow transition-colors">
                {child.label}
              </a>
            ))}
          </div>
        ) : (
          <a href={link.href}
             class="block py-2 font-russo text-off-white uppercase tracking-wide text-sm hover:text-comic-yellow transition-colors">
            {link.label}
          </a>
        )
      ))}
      <a href="/personalise" class="btn-primary text-sm py-2 px-5 mt-3 inline-block">
        Personalise
      </a>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  function updateNavState(scrolled: boolean) {
    if (scrolled) {
      navbar?.classList.add('bg-black', 'border-b-2', 'border-comic-red');
      navbar?.classList.remove('bg-transparent');
    } else {
      navbar?.classList.remove('bg-black', 'border-b-2', 'border-comic-red');
      navbar?.classList.add('bg-transparent');
    }
  }

  updateNavState(window.scrollY > 20);

  window.addEventListener('scroll', () => {
    updateNavState(window.scrollY > 20);
  });

  mobileMenuBtn?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden', !isHidden);
    closeIcon?.classList.toggle('hidden', isHidden);
  });

  import { cartCount, cartOpen } from '../stores/cart';

  const cartCountEl = document.getElementById('cart-count');
  const cartToggle = document.getElementById('cart-toggle');

  cartCount.subscribe((count) => {
    if (cartCountEl) {
      cartCountEl.textContent = String(count);
      if (count > 0) {
        cartCountEl.classList.remove('hidden');
      } else {
        cartCountEl.classList.add('hidden');
      }
    }
  });

  cartToggle?.addEventListener('click', () => {
    cartOpen.set(!cartOpen.get());
  });
</script>
