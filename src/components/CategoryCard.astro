---
interface Props {
  title: string;
  href: string;
  accent: 'red' | 'yellow' | 'cyan';
  description?: string;
  images?: string[];
}

const { title, href, accent, description, images = [] } = Astro.props;

const accentClasses = {
  red: { border: 'border-comic-red', bg: 'bg-comic-red', glow: 'hover:shadow-comic-red', text: 'text-comic-red' },
  yellow: { border: 'border-comic-yellow', bg: 'bg-comic-yellow', glow: 'hover:shadow-comic-yellow', text: 'text-comic-yellow' },
  cyan: { border: 'border-comic-cyan', bg: 'bg-comic-cyan', glow: 'hover:shadow-comic-cyan', text: 'text-comic-cyan' },
};

const classes = accentClasses[accent];
const carouselId = `carousel-${title.replace(/\s+/g, '-').toLowerCase()}`;
const hasMultiple = images.length > 1;
---

<a href={href}
   class={`group block bg-panel-dark border-4 ${classes.border} transition-all duration-300 hover:-translate-y-2 hover:scale-[1.02] overflow-hidden`}
   style={`box-shadow: 4px 4px 0 #000000;`}>
  <div class="aspect-[3/4] relative overflow-hidden bg-mid-grey" id={carouselId}>
    {images.length > 0 ? (
      images.map((img, i) => (
        <img
          src={img}
          alt={`${title} artwork ${i + 1}`}
          class={`carousel-img absolute inset-0 w-full h-full object-cover transition-opacity duration-700 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
          loading="lazy"
          data-index={i}
        />
      ))
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <span class="text-gray-500 font-russo tracking-widest text-xs uppercase">IMAGE</span>
      </div>
    )}
    <div class={`absolute inset-0 ${classes.bg} opacity-0 group-hover:opacity-10 transition-opacity duration-300`}></div>
  </div>
  <div class="p-5">
    <h3 class={`font-bangers text-2xl tracking-wide ${classes.text} group-hover:text-off-white transition-colors duration-200 uppercase`}>
      {title}
    </h3>
    {description && (
      <p class="font-source text-gray-400 text-sm mt-2 leading-relaxed">{description}</p>
    )}
    <div class={`mt-3 inline-flex items-center gap-2 font-russo text-sm ${classes.text} group-hover:gap-3 transition-all uppercase tracking-wide`}>
      Shop Now
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </div>
  </div>
</a>

{hasMultiple && (
  <script define:vars={{ carouselId, imageCount: images.length }}>
    (function() {
      const container = document.getElementById(carouselId);
      if (!container) return;

      const imgs = container.querySelectorAll('.carousel-img');
      if (imgs.length <= 1) return;

      let current = 0;
      let paused = false;

      function cycle() {
        if (paused) return;
        const next = (current + 1) % imgs.length;
        imgs[current].classList.remove('opacity-100');
        imgs[current].classList.add('opacity-0');
        imgs[next].classList.remove('opacity-0');
        imgs[next].classList.add('opacity-100');
        current = next;
      }

      const interval = setInterval(cycle, 3000);

      container.closest('a')?.addEventListener('mouseenter', () => { paused = true; });
      container.closest('a')?.addEventListener('mouseleave', () => { paused = false; });
    })();
  </script>
)}
