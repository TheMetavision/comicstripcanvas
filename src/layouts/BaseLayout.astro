---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CartPanel from '../components/CartPanel.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Comic Strip Canvas — UK-based pop culture wall art. Bold comic-book style canvas prints, framed prints, and posters. Personalised options available. Free UK P&P.',
  ogImage = 'https://assets.zyrosite.com/cdn-cgi/image/format=auto,w=768,fit=crop/dJobXo5wzMH13MyG/universal_upscale_0_378e8cac-370e-4b56-ab7d-cbb045eac260_0-AMqDnxJvzEiMXLvM.jpg',
  ogType = 'website',
  canonical,
  noindex = false,
} = Astro.props;

const siteUrl = 'https://comicstripcanvas.co.uk';
const pageUrl = canonical || `${siteUrl}${Astro.url.pathname}`;
const fullTitle = `${title} | Comic Strip Canvas`;

// Breadcrumb from URL path
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = [
  { name: 'Home', url: siteUrl },
  ...pathSegments.map((seg, i) => ({
    name: seg.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
    url: `${siteUrl}/${pathSegments.slice(0, i + 1).join('/')}`,
  })),
];
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-TLR2F74');</script>
  <!-- End Google Tag Manager -->

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={pageUrl} />
  <meta name="author" content="Comic Strip Canvas" />
  <meta name="geo.region" content="GB" />
  <meta name="geo.country" content="GB" />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:site_name" content="Comic Strip Canvas" />
  <meta property="og:locale" content="en_GB" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Organization + LocalBusiness Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["Organization", "LocalBusiness"],
    "name": "Comic Strip Canvas",
    "alternateName": "CSC",
    "description": "UK-based pop culture wall art brand. Bold comic-book style canvas prints, framed prints, and posters. Personalised artwork from your own photos.",
    "url": siteUrl,
    "logo": ogImage,
    "image": ogImage,
    "priceRange": "£9.99 - £46.99",
    "currenciesAccepted": "GBP",
    "paymentAccepted": "Credit Card, Debit Card",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "GB",
    },
    "areaServed": {
      "@type": "Country",
      "name": "United Kingdom",
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Comic Strip Canvas Products",
      "itemListElement": [
        {
          "@type": "OfferCatalog",
          "name": "Comic Book Covers",
          "url": `${siteUrl}/store/comic-book-covers`,
        },
        {
          "@type": "OfferCatalog",
          "name": "Comic Book Icons",
          "url": `${siteUrl}/store/comic-book-icons`,
        },
        {
          "@type": "OfferCatalog",
          "name": "Comic Book Strips",
          "url": `${siteUrl}/store/comic-book-strips`,
        },
        {
          "@type": "OfferCatalog",
          "name": "Personalised Products",
          "url": `${siteUrl}/store/personalised`,
        },
      ],
    },
    "sameAs": [],
  })}></script>

  <!-- BreadcrumbList Schema (all pages) -->
  {breadcrumbItems.length > 1 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbItems.map((item, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": item.name,
        "item": item.url,
      })),
    })}></script>
  )}

  <!-- WebSite Schema for sitelinks search -->
  {Astro.url.pathname === '/' && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Comic Strip Canvas",
      "url": siteUrl,
      "potentialAction": {
        "@type": "SearchAction",
        "target": `${siteUrl}/store?q={search_term_string}`,
        "query-input": "required name=search_term_string",
      },
    })}></script>
  )}

  <!-- FAQPage Schema (/personalise/) -->
  {Astro.url.pathname === '/personalise/' && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How does the personalised service work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Simply choose your style (Comic Book Cover, Pop Art Icon, or Comic Strip), upload your photo(s), provide any customisation details, and place your order. Our artists will create a digital proof within 24-48 hours. Once you approve the proof, we print and dispatch your artwork."
          }
        },
        {
          "@type": "Question",
          "name": "What sizes are available?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We offer three sizes: Small (12x8\"), Medium (16x12\"), and Large (24x16\"). All sizes are available as Poster Prints, Canvas Standard Frame, and Canvas Gallery Frame."
          }
        },
        {
          "@type": "Question",
          "name": "What styles can I choose from?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We offer three distinct styles: Comic Book Covers (bold, dramatic panel-style covers), Comic Book Icons (pop-art inspired graphic portraits), and Comic Book Strips (multi-panel sequential storytelling). Each style is also available as a ready-made design or fully personalised with your own photos."
          }
        },
        {
          "@type": "Question",
          "name": "Will I get to see a proof before you print?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes! For all personalised orders, we send a digital proof via email within 24-48 hours of receiving your order. You can request up to two rounds of revisions before we go to print. We don't start printing until you've given your approval."
          }
        },
        {
          "@type": "Question",
          "name": "How long does delivery take?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For personalised items, please allow 3-6 working days from proof approval. For standard (non-personalised) prints, allow 3-5 working days. All orders are sent via tracked delivery. You'll receive a tracking number when your order ships."
          }
        },
        {
          "@type": "Question",
          "name": "Do you ship internationally?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Currently we ship to mainland UK only, with free P&P included on all orders. We're working on expanding to Europe and further afield — sign up to our newsletter to be notified when international shipping launches."
          }
        },
        {
          "@type": "Question",
          "name": "What is your returns policy?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Because our products are made to order, we cannot accept returns unless the item is faulty or damaged. If your order arrives damaged, please contact us within 48 hours with photos and we'll arrange a replacement. Personalised items cannot be returned unless they arrive with a printing defect."
          }
        },
        {
          "@type": "Question",
          "name": "What photo do I need to send for a personalised comic canvas?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The better your photo, the bolder your finished piece. We accept JPG (.jpg / .jpeg) and PNG files only. For the sharpest result, your image should be at least 2,000 pixels on the shortest side — for larger print sizes, 3,000 pixels or above will give you the best quality. If you are unsure, upload what you have and we will let you know within 24 hours. Photo quality matters. Blurry or low-resolution originals can affect the clarity of the finished artwork — we will always sharpen and enhance where we can, but a crisp, well-lit original will always produce the most vibrant result. The pose in your photo is the pose in your artwork. If your subject is facing away, looking to the side, or mid-action, that is exactly how your commission will be illustrated — so choose a photo that shows them how you want them to be remembered. For Comic Book Covers and Comic Book Icons, upload one photo. For Comic Book Strips, 12 photos are required — each panel in the strip is built from a different image, so all 12 slots need to be filled to complete your commission."
          }
        }
      ]
    })}></script>
  )}
</head>
<body class="min-h-screen flex flex-col">
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TLR2F74"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

  <Navbar />
  <main class="flex-1 pt-24 lg:pt-28">
    <slot />
  </main>
  <Footer />
  <CartPanel />

  <script>
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );
    reveals.forEach((el) => observer.observe(el));
  </script>
</body>
</html>
