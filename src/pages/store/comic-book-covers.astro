---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { sanityClient } from '../../lib/sanity';
import { productsByCategoryQuery } from '../../lib/queries';

const products = await sanityClient.fetch(productsByCategoryQuery, { category: 'comic-book-covers' });
---

<BaseLayout
  title="Comic Book Cover Art UK"
  description="Bold, vintage-style comic book cover art prints. Iconic figures reimagined as dramatic magazine cover stars. Canvas prints, framed prints & posters from £9.99. Free UK P&P."
>
  <section class="relative bg-panel-dark py-16 overflow-hidden">
    <div class="absolute inset-0 halftone-bg opacity-40"></div>
    <div class="absolute top-0 left-0 right-0 h-1 bg-comic-red"></div>
    <div class="absolute inset-0" style="background: radial-gradient(circle at 80% 50%, rgba(236,0,140,0.15) 0%, transparent 50%);"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <nav class="flex items-center gap-2 font-source text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-comic-yellow transition-colors">Home</a>
        <span>/</span>
        <a href="/store" class="hover:text-comic-yellow transition-colors">Store</a>
        <span>/</span>
        <span class="text-off-white">Comic Book Covers</span>
      </nav>
      <div class="kapow-badge inline-block mb-4">Bold & Dramatic</div>
      <h1 class="font-bangers text-5xl md:text-7xl text-off-white tracking-wide mb-4"
          style="text-shadow: 4px 4px 0 rgba(0,0,0,0.5);">
        COMIC BOOK <span class="text-comic-red">COVER ART UK</span>
      </h1>
      <p class="font-source text-gray-300 text-lg max-w-2xl">
        Icons as you've never seen them before. Dramatic, vintage-inspired cover art with bold compositions and classic comic book colour palettes — make your walls the hero of the room.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {products.map((product) => (
        <ProductCard product={product} />
      ))}
    </div>
    <div class="mt-12 text-center bg-panel-dark border-4 border-comic-red p-8" style="box-shadow: 4px 4px 0 #000;">
      <h2 class="font-bangers text-3xl text-off-white mb-3 tracking-wide">WANT YOUR FACE ON THE COVER?</h2>
      <p class="font-source text-gray-300 mb-6">We can turn your photo into a personalised comic book cover. You become the hero.</p>
      <a href="/personalised" class="btn-primary">START YOUR CUSTOM COVER</a>
    </div>
  </div>

  <!-- SEO Content Block -->
  <section class="bg-charcoal border-t-4 border-black py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose-comic">
        <p class="font-source text-gray-300 text-lg leading-relaxed mb-4">
          The comic book cover is one of the most striking visual formats ever created — bold typography, dramatic composition, a single iconic figure demanding your attention from the rack. Comic Strip Canvas takes that visual language and applies it to the icons who deserve it most: the film legends, music heroes, and cult characters who have earned their place on your wall.
        </p>
        <p class="font-source text-gray-300 text-lg leading-relaxed mb-4">
          Each comic book canvas print reimagines a cultural icon as the star of their own magazine cover — with all the graphic drama, vivid colour, and KA-POW! energy that format commands. Browse pop culture wall art that spans the golden age of Hollywood through to cult cinema and contemporary legends, from Dirty Harry's unflinching cool to Marilyn Monroe's timeless presence. Three formats — canvas print, framed print, and poster — each available in three sizes.
        </p>
        <p class="font-source text-gray-300 text-lg leading-relaxed mb-4">
          For the film obsessive who has seen everything. For the music lover who has heard everything. For the gift buyer who wants something genuinely original rather than another generic present. Comic book cover art is a gift with impact — the kind that earns a permanent spot on the wall rather than a polite thank you.
        </p>
        <p class="font-source text-gray-300 text-lg leading-relaxed">
          If you want a comic book cover created from your own photo, that's exactly what we do too. <a href="/personalised" class="text-comic-red hover:text-comic-yellow transition-colors font-semibold">Discover our personalised comic book covers →</a>
        </p>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://comicstripcanvas.co.uk" },
      { "@type": "ListItem", "position": 2, "name": "Store", "item": "https://comicstripcanvas.co.uk/store" },
      { "@type": "ListItem", "position": 3, "name": "Comic Book Covers", "item": "https://comicstripcanvas.co.uk/store/comic-book-covers" }
    ]
  })}></script>
</BaseLayout>
