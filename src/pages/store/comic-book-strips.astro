---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { sanityClient } from '../../lib/sanity';
import { productsByCategoryQuery } from '../../lib/queries';

const products = await sanityClient.fetch(productsByCategoryQuery, { category: 'comic-book-strips' });
---

<BaseLayout
  title="Comic Strip Wall Art UK — Multi-Panel Stories That Hit Hard"
  description="Bold multi-panel comic strip wall art. Iconic scenes from film, music and sport rendered in vivid comic book style. Canvas prints, framed prints & posters from £9.99. Free UK P&P."
>
  <section class="relative bg-panel-dark py-16 overflow-hidden">
    <div class="absolute inset-0 halftone-bg opacity-40"></div>
    <div class="absolute top-0 left-0 right-0 h-1 bg-comic-cyan"></div>
    <div class="absolute inset-0" style="background: radial-gradient(circle at 80% 50%, rgba(0,229,255,0.12) 0%, transparent 50%);"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <nav class="flex items-center gap-2 font-source text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-comic-yellow transition-colors">Home</a>
        <span>/</span>
        <a href="/store" class="hover:text-comic-yellow transition-colors">Store</a>
        <span>/</span>
        <span class="text-off-white">Comic Book Strips</span>
      </nav>
      <div class="kapow-badge inline-block mb-4">Multi-Panel. Maximum Drama.</div>
      <h1 class="font-bangers text-5xl md:text-7xl text-off-white tracking-wide mb-4"
          style="text-shadow: 4px 4px 0 rgba(0,0,0,0.5);">
        COMIC STRIP <span class="text-comic-cyan">WALL ART UK</span>
      </h1>
      <p class="font-source text-gray-300 text-lg max-w-2xl">
        Some stories can't be told in a single frame. Multi-panel comic strip wall art that captures the drama, humour, and pure brilliance of the most iconic moments in film, music, and sport.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {products.map((product) => (
        <ProductCard product={product} />
      ))}
    </div>
    <div class="mt-12 text-center bg-panel-dark border-4 border-comic-cyan p-8" style="box-shadow: 4px 4px 0 #000;">
      <h2 class="font-bangers text-3xl text-off-white mb-3 tracking-wide">WANT YOUR STORY IN PANELS?</h2>
      <p class="font-source text-gray-300 mb-6">We can turn your photos and memories into a personalised comic strip. Your moment. Your panels. Your wall.</p>
      <a href="/personalised" class="btn-primary">CREATE YOUR STRIP</a>
    </div>
  </div>

  <!-- SEO Content Block -->
  <section class="bg-charcoal border-t-4 border-black py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose-comic">
        <p class="font-source text-gray-300 text-lg leading-relaxed mb-4">
          Some stories can't be told in a single frame. That's why comic strip wall art exists — and that's why Comic Strip Canvas has built a range that takes the most iconic moments from film, music, and sport and turns them into bold, multi-panel narratives that demand a place on your wall.
        </p>
        <p class="font-source text-gray-300 text-lg leading-relaxed mb-4">
          Each comic strip canvas print tells its story across a sequence of panels, capturing the drama, the humour, the tension, or the pure brilliance of the moment in vivid comic book style. From the chaos of Gremlins to the swagger of Scarface, from Grease's legendary pink ladies to the sporting moments that stopped the nation — this is comic book strip art at its most cinematic.
        </p>
        <p class="font-source text-gray-300 text-lg leading-relaxed mb-4">
          Every piece in the collection is available in three formats — canvas print, framed print, and poster — and in three sizes, so you'll find the right fit for any wall. Made to order and printed to a quality that holds up at close range, these aren't the kind of prints that disappear into the background.
        </p>
        <p class="font-source text-gray-300 text-lg leading-relaxed">
          For birthdays, Father's Day, and Christmas, a comic strip canvas is the gift for the film obsessive, the music devotee, and the sport fanatic who wants art on their wall that actually means something. Bold, vivid, and personal — even when it's not personalised. Want something made entirely for you? <a href="/personalised" class="text-comic-cyan hover:text-comic-yellow transition-colors font-semibold">Explore our personalised comic art →</a>
        </p>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://comicstripcanvas.co.uk" },
      { "@type": "ListItem", "position": 2, "name": "Store", "item": "https://comicstripcanvas.co.uk/store" },
      { "@type": "ListItem", "position": 3, "name": "Comic Book Strips", "item": "https://comicstripcanvas.co.uk/store/comic-book-strips" }
    ]
  })}></script>
</BaseLayout>
