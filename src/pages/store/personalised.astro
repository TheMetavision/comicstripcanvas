---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { sanityClient } from '../../lib/sanity';
import { productsByCategoryQuery } from '../../lib/queries';

const products = await sanityClient.fetch(productsByCategoryQuery, { category: 'personalised' });
---

<BaseLayout
  title="Personalised Comic Art UK | Custom Comic Canvas Gifts"
  description="Turn your photo into stunning personalised comic art — hand-illustrated, made to order. Comic book covers, strips and icons. The ultimate unique gift. Order from Comic Strip Canvas."
>
  <section class="relative bg-panel-dark py-16 overflow-hidden">
    <div class="absolute inset-0 halftone-bg opacity-40"></div>
    <div class="absolute top-0 left-0 right-0 h-1 bg-comic-red"></div>
    <div class="absolute inset-0" style="background: radial-gradient(circle at 80% 50%, rgba(236,0,140,0.15) 0%, transparent 50%);"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <nav class="flex items-center gap-2 font-source text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-comic-yellow transition-colors">Home</a>
        <span>/</span>
        <span class="text-off-white">Personalised Comic Art</span>
      </nav>
      <div class="kapow-badge inline-block mb-4">Made for You. Only for You.</div>
      <h1 class="font-bangers text-5xl md:text-7xl text-off-white tracking-wide mb-4"
          style="text-shadow: 4px 4px 0 rgba(0,0,0,0.5);">
        PERSONALISED <span class="text-comic-red">COMIC ART UK</span>
      </h1>
      <p class="font-source text-gray-300 text-lg max-w-2xl">
        Become the hero of your own story. We take your photo and hand-illustrate it into bold, vivid personalised comic art — made to order, unique to you.
      </p>
    </div>
  </section>

  <!-- Body copy above product showcase -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-6">
    <div class="max-w-4xl">
      <p class="font-source text-gray-300 text-lg leading-relaxed mb-4">
        Your photo. Your moment. Your story — rendered in bold, vivid personalised comic art that stops people in their tracks. At Comic Strip Canvas, we take your image and transform it into the kind of wall art you genuinely can't find anywhere else: hand-illustrated, made to order, and built to hit the wall with maximum KA-POW!
      </p>
      <p class="font-source text-gray-300 text-lg leading-relaxed mb-4">
        Choose from three personalised styles. A personalised comic book cover turns you — or the person you're buying for — into a magazine cover star, surrounded by bold graphic design and all the drama of a classic front page. A personalised comic strip tells a story across multiple panels: a wedding, a sporting moment, a family portrait that looks anything but ordinary. A personalised comic book icon piece captures a single subject with all the bold, graphic intensity the format commands.
      </p>
      <p class="font-source text-gray-300 text-lg leading-relaxed mb-4">
        Every piece begins with your photo. You upload it through our simple upload portal, we create the artwork, and we share a preview for your approval before anything goes to print. The result is a hand-illustrated, made-to-order piece that is entirely and unmistakably yours.
      </p>
      <p class="font-source text-gray-300 text-lg leading-relaxed mb-6">
        For birthdays, Father's Day, Mother's Day, Christmas, and anniversaries — this is the gift that lands differently. Not a voucher. Not a generic present. A piece of art made for a specific person, to celebrate a specific moment. The gift they will actually remember.
      </p>
      <a href="https://form.jotform.com/252743272336356" class="btn-primary inline-block" target="_blank" rel="noopener noreferrer">UPLOAD YOUR PHOTO AND START YOUR COMMISSION →</a>
    </div>
  </div>

  <!-- Product Grid -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    {products.length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {products.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    )}
  </div>

  <!-- FAQ Section -->
  <section class="bg-charcoal border-t-4 border-black py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-bangers text-4xl text-off-white tracking-wide mb-10"
          style="text-shadow: 3px 3px 0 rgba(0,0,0,0.5);">
        FREQUENTLY ASKED <span class="text-comic-red">QUESTIONS</span>
      </h2>

      <div class="space-y-8">

        <div class="border-l-4 border-comic-red pl-6">
          <h3 class="font-russo text-off-white text-lg mb-3">Can I get personalised comic art made from my own photo?</h3>
          <p class="font-source text-gray-300 leading-relaxed">
            Yes — that is exactly what we do. At Comic Strip Canvas, every personalised piece starts with your photo. You upload it through our secure portal, our artists hand-illustrate your commission in bold comic book style, and we share a preview for your approval before it goes to print. The result is a one-of-a-kind piece of personalised comic art made entirely for you.
          </p>
        </div>

        <div class="border-l-4 border-comic-red pl-6">
          <h3 class="font-russo text-off-white text-lg mb-3">How do I order a personalised comic canvas from Comic Strip Canvas?</h3>
          <p class="font-source text-gray-300 leading-relaxed">
            Ordering personalised comic art from Comic Strip Canvas is simple. First, upload your chosen photo using our <a href="https://form.jotform.com/252743272336356" class="text-comic-red hover:text-comic-yellow transition-colors font-semibold" target="_blank" rel="noopener noreferrer">personalisation upload portal</a>. We review your image within 24 hours and confirm your commission. Our artists then hand-illustrate your piece, and we send you a preview to approve. Once you give the green light, your canvas goes to print and is dispatched to your door.
          </p>
        </div>

        <div class="border-l-4 border-comic-red pl-6">
          <h3 class="font-russo text-off-white text-lg mb-3">What personalised comic styles are available?</h3>
          <p class="font-source text-gray-300 leading-relaxed">
            We offer three personalised formats. A personalised comic book cover reimagines you as a magazine cover star — bold, graphic, and genuinely impressive. A personalised comic strip tells your story across multiple dramatic panels. A personalised comic book icon piece captures a single subject in vivid, high-impact comic style. All three are available in multiple sizes and formats.
          </p>
        </div>

        <div class="border-l-4 border-comic-red pl-6">
          <h3 class="font-russo text-off-white text-lg mb-3">How long does a personalised comic canvas take to make?</h3>
          <p class="font-source text-gray-300 leading-relaxed">
            Each personalised comic art piece is hand-illustrated and made to order. Once you upload your photo, you'll receive a digital proof within 24–48 hours. After you approve it, printing and delivery to any UK mainland address takes a further 3–6 working days. We always recommend ordering well in advance for gifting occasions — particularly Father's Day, Christmas, and birthdays — to make sure your piece arrives with time to spare.
          </p>
        </div>

        <div class="border-l-4 border-comic-red pl-6">
          <h3 class="font-russo text-off-white text-lg mb-3">Is personalised comic art a good gift idea?</h3>
          <p class="font-source text-gray-300 leading-relaxed">
            It is one of the most original gifts you can give. Personalised comic art from Comic Strip Canvas takes a generic "I didn't know what to get" problem and turns it into a bold, emotional, one-of-a-kind piece of wall art. It works brilliantly for birthdays, Father's Day, Mother's Day, Christmas, and anniversaries — and it is the kind of gift that gets framed, displayed, and talked about for years. Perfect for someone who has everything. Perfect for someone who means everything.
          </p>
        </div>

        <div class="border-l-4 border-comic-red pl-6">
          <h3 class="font-russo text-off-white text-lg mb-3">What photo do I need to send for a personalised comic canvas?</h3>
          <p class="font-source text-gray-300 leading-relaxed">
            For best results, we recommend a clear, well-lit photograph where the subject's face is visible and unobstructed. A high-resolution image will always produce the sharpest, most vibrant result. If you are unsure whether your photo will work, upload it through our portal and our team will review it within 24 hours — we will let you know if we need anything different before your commission begins.
          </p>
        </div>

      </div>

      <div class="mt-12 text-center">
        <a href="https://form.jotform.com/252743272336356" class="btn-primary inline-block" target="_blank" rel="noopener noreferrer">START YOUR COMMISSION →</a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://comicstripcanvas.co.uk" },
      { "@type": "ListItem", "position": 2, "name": "Personalised Comic Art", "item": "https://comicstripcanvas.co.uk/personalised" }
    ]
  })}></script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Can I get personalised comic art made from my own photo?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes — that is exactly what we do. At Comic Strip Canvas, every personalised piece starts with your photo. You upload it through our secure portal, our artists hand-illustrate your commission in bold comic book style, and we share a preview for your approval before it goes to print. The result is a one-of-a-kind piece of personalised comic art made entirely for you."
        }
      },
      {
        "@type": "Question",
        "name": "How do I order a personalised comic canvas from Comic Strip Canvas?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ordering personalised comic art from Comic Strip Canvas is simple. First, upload your chosen photo using our personalisation upload portal at https://form.jotform.com/252743272336356. We review your image within 24 hours and confirm your commission. Our artists then hand-illustrate your piece, and we send you a preview to approve. Once you give the green light, your canvas goes to print and is dispatched to your door."
        }
      },
      {
        "@type": "Question",
        "name": "What personalised comic styles are available?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We offer three personalised formats. A personalised comic book cover reimagines you as a magazine cover star — bold, graphic, and genuinely impressive. A personalised comic strip tells your story across multiple dramatic panels. A personalised comic book icon piece captures a single subject in vivid, high-impact comic style. All three are available in multiple sizes and formats."
        }
      },
      {
        "@type": "Question",
        "name": "How long does a personalised comic canvas take to make?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Each personalised comic art piece is hand-illustrated and made to order. Once you upload your photo, you'll receive a digital proof within 24–48 hours. After you approve it, printing and delivery to any UK mainland address takes a further 3–6 working days."
        }
      },
      {
        "@type": "Question",
        "name": "Is personalised comic art a good gift idea?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "It is one of the most original gifts you can give. Personalised comic art from Comic Strip Canvas takes a generic gift problem and turns it into a bold, emotional, one-of-a-kind piece of wall art. It works brilliantly for birthdays, Father's Day, Mother's Day, Christmas, and anniversaries — and it is the kind of gift that gets framed, displayed, and talked about for years."
        }
      },
      {
        "@type": "Question",
        "name": "What photo do I need to send for a personalised comic canvas?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For best results, we recommend a clear, well-lit photograph where the subject's face is visible and unobstructed. A high-resolution image will always produce the sharpest, most vibrant result. If you are unsure whether your photo will work, upload it through our portal and our team will review it within 24 hours."
        }
      }
    ]
  })}></script>
</BaseLayout>
