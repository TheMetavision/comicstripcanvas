---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryCard from '../components/CategoryCard.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { sanityClient, urlFor } from '../lib/sanity';
import { testimonialsQuery } from '../lib/queries';

const testimonials = await sanityClient.fetch(testimonialsQuery);

// Fetch product images for category card carousels (6 per category)
const categoryImages = await sanityClient.fetch(`{
  "covers": *[_type == "product" && category == "comic-book-covers" && count(images) > 0] | order(sortOrder asc)[0..5].images[0],
  "icons": *[_type == "product" && category == "comic-book-icons" && count(images) > 0] | order(sortOrder asc)[0..5].images[0],
  "strips": *[_type == "product" && category == "comic-book-strips" && count(images) > 0] | order(sortOrder asc)[0..5].images[0]
}`);

const coverImages = (categoryImages.covers || []).filter((img: any) => img?.asset).map((img: any) => urlFor(img).width(600).height(400).url());
const iconImages = (categoryImages.icons || []).filter((img: any) => img?.asset).map((img: any) => urlFor(img).width(600).height(400).url());
const stripImages = (categoryImages.strips || []).filter((img: any) => img?.asset).map((img: any) => urlFor(img).width(600).height(400).url());
---

<BaseLayout
  title="Epic Pop Culture Wall Art"
  description="Comic Strip Canvas — UK's boldest comic-book style wall art. Canvas prints, framed prints & posters. Personalised options available. Free UK P&P."
>
  <!-- Hero -->
  <section class="relative bg-charcoal overflow-hidden clip-diagonal" style="padding-bottom: 8rem;">
    <div class="absolute inset-0 halftone-bg opacity-60"></div>
    <div class="absolute inset-0" style="background: radial-gradient(circle at 15% 50%, rgba(236,0,140,0.2) 0%, transparent 55%), radial-gradient(circle at 85% 30%, rgba(0,174,239,0.12) 0%, transparent 45%);"></div>
    <div class="absolute top-0 left-0 right-0 h-1 bg-comic-red"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-40">
      <div class="max-w-3xl">
        <div class="speech-bubble inline-block mb-6 text-sm">
          KA-POW! WALL ART IS HERE!
        </div>
        <h1 class="font-bangers text-off-white leading-none mb-6 text-5xl sm:text-7xl lg:text-9xl"
            style="letter-spacing: 0.03em; text-shadow: 5px 5px 0 rgba(0,0,0,0.6);">
          EPIC MOMENTS.
          <span class="text-comic-yellow block">COMIC STYLE.</span>
        </h1>
        <p class="font-source text-gray-300 text-lg lg:text-xl leading-relaxed mb-10 max-w-xl">
          Bold, vibrant comic-book wall art for your home. Canvas prints, framed prints, and posters — plus fully personalised artwork made just for you.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/store" class="btn-primary text-xl">EXPLORE THE STORE</a>
          <a href="/personalise" class="btn-secondary text-xl">PERSONALISE YOURS</a>
        </div>
        <div class="flex flex-wrap items-center gap-6 mt-8">
          <div class="flex items-center gap-2">
            <div class="flex gap-0.5">
              {Array(5).fill(null).map(() => (
                <svg class="w-4 h-4 text-comic-yellow" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="font-russo text-off-white text-sm">5-Star Reviews</span>
          </div>
          <div class="w-px h-5 bg-gray-600"></div>
          <span class="font-source text-gray-400 text-sm">Free UK P&P</span>
          <div class="w-px h-5 bg-gray-600"></div>
          <span class="font-source text-gray-400 text-sm">Made to Order</span>
        </div>
      </div>
    </div>

    <div class="absolute top-12 right-8 hidden lg:block select-none pointer-events-none">
      <div class="font-bangers text-9xl text-comic-yellow opacity-20 rotate-12"
           style="letter-spacing: 0.05em; -webkit-text-stroke: 3px rgba(255,242,0,0.3);">
        POW!
      </div>
    </div>
    <div class="absolute bottom-24 right-1/3 hidden xl:block select-none pointer-events-none">
      <div class="font-bangers text-5xl text-comic-red opacity-15 -rotate-6">
        BOOM!
      </div>
    </div>
  </section>

  <!-- Category Showcase -->
  <section class="py-20 bg-charcoal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2 class="section-heading mb-3">SHOP BY STYLE</h2>
        <p class="font-source text-gray-400 text-lg max-w-xl mx-auto">
          Three distinct comic art styles — each bold, vibrant, and perfect for any wall.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="reveal stagger-1">
          <CategoryCard
            title="Comic Book Covers"
            href="/store/comic-book-covers"
            accent="red"
            description="Dramatic vintage-inspired comic book cover art. Heroes, villains, and epic scenes."
            images={coverImages}
          />
        </div>
        <div class="reveal stagger-2">
          <CategoryCard
            title="Comic Book Icons"
            href="/store/comic-book-icons"
            accent="yellow"
            description="Bold pop-art graphic portraits and iconic character studies in vivid colour."
            images={iconImages}
          />
        </div>
        <div class="reveal stagger-3">
          <CategoryCard
            title="Comic Book Strips"
            href="/store/comic-book-strips"
            accent="cyan"
            description="Classic multi-panel storytelling art. Action, humour, and narrative in print."
            images={stripImages}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Quality Section -->
  <section class="py-20 diagonal-stripes bg-panel-dark relative overflow-hidden">
    <div class="absolute inset-0 halftone-bg-subtle"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <div class="kapow-badge inline-block mb-6">Premium Quality</div>
          <h2 class="section-heading mb-6">QUALITY WITHOUT COMPROMISE</h2>
          <p class="font-source text-gray-300 text-lg leading-relaxed mb-8">
            Every piece of Comic Strip Canvas wall art is printed to the highest standard using premium materials that make colours pop and details sing. Your artwork deserves nothing less.
          </p>
          <div class="space-y-5">
            {[
              { title: 'Comic Book Covers', desc: 'Dramatic, vintage-inspired cover art with bold compositions and classic colour palettes.', color: 'bg-comic-red' },
              { title: 'Comic Book Icons', desc: 'Bold graphic portraits with a pop-art edge — powerful, striking, and unmistakably unique.', color: 'bg-comic-yellow' },
              { title: 'Comic Book Strips', desc: 'Multi-panel storytelling art that captures moments, emotions, and action in sequence.', color: 'bg-comic-cyan' },
            ].map((item) => (
              <div class="flex gap-4 items-start">
                <div class={`w-3 h-3 ${item.color} border-2 border-black flex-shrink-0 mt-1.5`}></div>
                <div>
                  <h3 class="font-russo text-off-white mb-1 text-sm uppercase tracking-wide">{item.title}</h3>
                  <p class="font-source text-gray-400 text-sm leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-8">
            <a href="/services" class="btn-primary">View Formats & Pricing</a>
          </div>
        </div>
        <div class="reveal stagger-2">
          <div class="aspect-[4/3] border-4 border-black overflow-hidden" style="box-shadow: 8px 8px 0 #000000;">
            <img src="/studio-hero.png" alt="Comic Strip Canvas print studio with Epson large format printer" class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Personalised Products -->
  <section class="py-20 bg-charcoal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <div class="speech-bubble inline-block mb-6">It's all about YOU!</div>
        <h2 class="section-heading mb-4">TURN YOUR OWN PHOTOS INTO<br class="hidden md:block"/>WALL-ART HEROES</h2>
        <p class="font-source text-gray-400 text-lg max-w-2xl mx-auto">
          Your photos. Your story. Our art. We transform your favourite pictures into one-of-a-kind comic book masterpieces.
        </p>
      </div>

      <div class="space-y-16">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center reveal stagger-1">
          <div>
            <div class="aspect-video border-4 border-comic-red overflow-hidden" style="box-shadow: 6px 6px 0 #000000;">
              <img src="https://cdn.sanity.io/images/lwbwahym/production/ea1e54dd3477bbbfbf2a13a8761a048a6a2f30b6-2752x1536.jpg" alt="Personalised comic book cover example — wedding KA-POW canvas on wall" class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>
          <div>
            <span class="font-bangers text-7xl text-comic-red opacity-20 leading-none block mb-2">01</span>
            <h3 class="font-bangers text-3xl lg:text-4xl text-off-white mb-4 tracking-wide">Star on Your Own Comic Book Cover</h3>
            <p class="font-source text-gray-300 leading-relaxed mb-6 text-lg">
              Imagine yourself as the hero — or villain — of your very own comic book cover. We take your photo and transform it into a stunning, vintage-style cover complete with your name in lights, dramatic background art, and that unmistakable comic book feel.
            </p>
            <a href="/personalise" class="btn-primary">START YOUR CUSTOM ORDER</a>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center reveal stagger-2">
          <div class="order-2 lg:order-1">
            <span class="font-bangers text-7xl text-comic-yellow opacity-20 leading-none block mb-2">02</span>
            <h3 class="font-bangers text-3xl lg:text-4xl text-off-white mb-4 tracking-wide">Your Portrait as a Pop Culture Icon</h3>
            <p class="font-source text-gray-300 leading-relaxed mb-6 text-lg">
              Channel your inner Andy Warhol. We transform your portrait into a bold, graphic pop-art icon in vivid primary colours and clean graphic lines. The result is striking, contemporary, and totally unique — a piece that belongs in a gallery.
            </p>
            <a href="/personalise" class="btn-primary">START YOUR CUSTOM ORDER</a>
          </div>
          <div class="order-1 lg:order-2">
            <div class="aspect-video border-4 border-comic-yellow overflow-hidden" style="box-shadow: 6px 6px 0 #000000;">
              <img src="https://cdn.sanity.io/images/lwbwahym/production/a30bbbcbffdf8289dd7b3def522f2075abe2e50d-2752x1536.jpg" alt="Personalised comic icon example — Mia friendships canvas on wall" class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center reveal stagger-3">
          <div>
            <div class="aspect-video border-4 border-comic-cyan overflow-hidden" style="box-shadow: 6px 6px 0 #000000;">
              <img src="https://cdn.sanity.io/images/lwbwahym/production/5895d21b1e695781263a08dc0acf608cdc8c098f-1248x832.jpg" alt="Personalised comic strip example — graduation story canvas on wall" class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>
          <div>
            <span class="font-bangers text-7xl text-comic-cyan opacity-20 leading-none block mb-2">03</span>
            <h3 class="font-bangers text-3xl lg:text-4xl text-off-white mb-4 tracking-wide">Tell Your Story, Frame by Frame</h3>
            <p class="font-source text-gray-300 leading-relaxed mb-6 text-lg">
              From that epic holiday adventure to the story of how you met — a personalised comic strip captures your memories in a format unlike any other. Provide your photos and details, and we'll craft a bespoke multi-panel narrative you'll treasure forever.
            </p>
            <a href="/personalise" class="btn-primary">START YOUR CUSTOM ORDER</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <TestimonialCarousel testimonials={testimonials} />

  <!-- Newsletter -->
  <NewsletterSignup />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Comic Strip Canvas",
    "url": "https://comicstripcanvas.co.uk",
    "logo": "https://assets.zyrosite.com/cdn-cgi/image/format=auto,w=768,fit=crop/dJobXo5wzMH13MyG/universal_upscale_0_378e8cac-370e-4b56-ab7d-cbb045eac260_0-AMqDnxJvzEiMXLvM.jpg",
    "description": "UK-based pop culture wall art. Bold comic-book style canvas prints, framed prints, and posters.",
    "address": { "@type": "PostalAddress", "addressCountry": "GB" },
    "aggregateRating": testimonials.length > 0 ? {
      "@type": "AggregateRating",
      "ratingValue": (testimonials.reduce((sum: number, t: any) => sum + (t.rating || 5), 0) / testimonials.length).toFixed(1),
      "reviewCount": testimonials.length,
      "bestRating": "5",
      "worstRating": "1",
    } : undefined,
    "review": testimonials.slice(0, 5).map((t: any) => ({
      "@type": "Review",
      "author": { "@type": "Person", "name": t.customerName },
      "reviewRating": { "@type": "Rating", "ratingValue": t.rating, "bestRating": "5" },
      "reviewBody": t.quote,
    })),
  })}></script>
</BaseLayout>
