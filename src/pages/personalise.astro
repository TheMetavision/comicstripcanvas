---
import BaseLayout from '../layouts/BaseLayout.astro';
import PersonalisationWizard from '../components/PersonalisationWizard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { sanityClient } from '../lib/sanity';
import { faqsByPageQuery } from '../lib/queries';

const faqs = await sanityClient.fetch(faqsByPageQuery, { page: 'personalise' });
---

<BaseLayout
  title="Personalise Your Comic Art"
  description="Create a personalised comic book canvas print, framed print, or poster from your own photos. Comic covers, pop icons, and strip art. Made to order with 24-48hr proof."
>
  <section class="relative bg-panel-dark halftone-bg py-16 overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-1 bg-comic-red"></div>
    <div class="absolute inset-0" style="background: radial-gradient(circle at 20% 50%, rgba(255,242,0,0.08) 0%, transparent 50%), radial-gradient(circle at 80% 30%, rgba(236,0,140,0.12) 0%, transparent 45%);"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <nav class="flex items-center gap-2 font-source text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-comic-yellow transition-colors">Home</a>
        <span>/</span>
        <span class="text-off-white">Personalise</span>
      </nav>
      <div class="speech-bubble inline-block mb-6">Your Story. Our Art.</div>
      <h1 class="font-bangers text-5xl md:text-7xl text-off-white tracking-wide mb-4"
          style="text-shadow: 4px 4px 0 rgba(0,0,0,0.5);">
        CREATE YOUR OWN
        <span class="text-comic-yellow block">COMIC MASTERPIECE</span>
      </h1>
      <p class="font-source text-gray-300 text-lg max-w-2xl">
        Follow the steps below to design your personalised comic art. We'll send you a proof within 24-48 hours and get your artwork printed once you're happy.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <PersonalisationWizard />
  </div>

  <!-- FAQ -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <section class="mb-20 reveal">
      <div class="text-center mb-10">
        <h2 class="section-heading">FREQUENTLY ASKED QUESTIONS</h2>
      </div>
      <FAQAccordion faqs={faqs} />

      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqs.map((f: any) => ({
          "@type": "Question",
          "name": f.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": f.answer,
          },
        })),
      })}></script>
    </section>
  </div>

</BaseLayout>
